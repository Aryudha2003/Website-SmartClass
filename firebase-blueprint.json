{
  "entities": {
    "User": {
      "title": "User",
      "description": "Public user profile information.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "displayName", "email"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Room reservation record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "roomId": { "type": "string" },
        "roomName": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] }
      },
      "required": ["userId", "roomId", "startTime", "durationMinutes", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles indexed by UID."
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Global list of all room bookings."
    }
  }
}
