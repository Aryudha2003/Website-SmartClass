rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             data.keys().hasAll(['userId', 'displayName', 'email']) &&
             data.keys().size() <= 6;
    }

    match /users/{userId} {
      allow get, write: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastActive', 'email']);
    }

    // Booking Validation
    function isValidBooking(data) {
      return data.userId == request.auth.uid &&
             data.roomId is string && data.roomId.size() <= 50 &&
             data.roomName is string && data.roomName.size() <= 100 &&
             data.status in ['active', 'completed', 'cancelled'] &&
             data.keys().hasAll(['userId', 'roomId', 'roomName', 'startTime', 'durationMinutes', 'status']) &&
             data.keys().size() <= 10;
    }

    match /bookings/{bookingId} {
      // Users can only see their own bookings
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isVerified() && isValidId(bookingId) && isValidBooking(incoming()) &&
                    incoming().createdAt == request.time;
                    
      allow update: if isOwner(existing().userId) && isValidBooking(incoming()) &&
                    incoming().userId == existing().userId &&
                    incoming().createdAt == existing().createdAt &&
                    (
                      // Action: Cancel
                      (existing().status == 'active' && incoming().status == 'cancelled' && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
                    );
      
      allow delete: if false; // Prefer soft-delete/status change
    }
  }
}
